# ─── Dependencies ────────────────────────────────────────────────────────────
**/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Environment & secrets ───────────────────────────────────────────────────
# All .env variants — contains private keys, Supabase keys, API tokens
.env
.env.*
.env.local
.env.*.local

# Private key / certificate files
*.pem
*.key
*.p12
*.pfx

# Wallet keystore files
keystore/
*.keystore.json

# ─── Hardhat / Contracts ─────────────────────────────────────────────────────
packages/contracts/artifacts/
packages/contracts/cache/
packages/contracts/typechain-types/
packages/contracts/dist/

# ─── Next.js ─────────────────────────────────────────────────────────────────
**/.next/
**/out/
/build

# ─── Testing & coverage ──────────────────────────────────────────────────────
/coverage
**/coverage/

# ─── Debug logs ──────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── TypeScript build info ───────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── OS / editor artifacts ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/settings.json

# ─── Vercel ──────────────────────────────────────────────────────────────────
.vercel

# ─── Scratch / temporary work ────────────────────────────────────────────────
scratch/

# ─── Markdown (except READMEs) ───────────────────────────────────────────────
**/*.md
!**/README.md
!**/readme.md
!**/README.MD
!**/README
